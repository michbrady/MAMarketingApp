{
  "name": "unfranchise-backend",
  "version": "1.0.0",
  "description": "UnFranchise Marketing App - Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --ui --coverage",
    "test:setup": "tsx src/__tests__/setup/create-test-db.ts",
    "test:api": "vitest run src/__tests__/api",
    "test:auth": "vitest run src/__tests__/api/auth.test.ts",
    "test:content": "vitest run src/__tests__/api/content.test.ts",
    "test:contacts": "vitest run src/__tests__/api/contacts.test.ts",
    "test:followups": "vitest run src/__tests__/api/followups.test.ts",
    "test:sharing": "vitest run src/__tests__/api/sharing.test.ts",
    "test:analytics": "vitest run src/__tests__/api/analytics.test.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "unfranchise",
    "marketing",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "nanoid": "^5.0.9",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
